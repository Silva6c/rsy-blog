# ╔══════════════════════════════════════════════════════════════╗
# ║           零成本博客 — 环境变量配置说明                       ║
# ╚══════════════════════════════════════════════════════════════╝
#
# 📋 使用方式：
#   1. 复制本文件为 .env ： cp .env.example .env
#   2. 按照下方注释逐个填写你的免费服务密钥
#   3. 所有以 PUBLIC_ 开头的变量会被打包进客户端 JS，请勿放入敏感信息
#   4. ⚠️ .env 已被 .gitignore 忽略，绝对不会提交到 Git
#
# ⏱️ 预计耗时：30~45 分钟完成所有注册
# 💰 总费用：￥0.00

# ──────────────────────────────────────────────────────────────
# 🔐 Supabase — 认证 + 数据库
# ──────────────────────────────────────────────────────────────
# 免费额度：2 个项目 · 500MB 数据库 · 50,000 月活用户 · 5GB 带宽
#
# 📝 获取步骤：
#   1. 访问 https://supabase.com 并用 GitHub 账号注册/登录
#   2. 点击 "New project" 创建项目
#      - Organization: 选择默认的（没有就创建一个）
#      - Name: 随便填（如 my-blog）
#      - Database Password: 生成一个强密码（记下来！后续 SQL 迁移要用）
#      - Region: 选择离你最近的（亚太选 ap-southeast-1 新加坡）
#      - Pricing Plan: 选 FREE（默认）
#   3. 等待项目初始化完成（约 2 分钟）
#   4. 进入项目 Dashboard → 左侧 Settings → API
#   5. 复制以下两个值：
#      - Project URL（就是下面的 PUBLIC_SUPABASE_URL）
#      - anon/public key（就是下面的 PUBLIC_SUPABASE_ANON_KEY）
#   6. ⚠️ SERVICE_ROLE_KEY 仅用于服务端（如构建时数据拉取），不要用 PUBLIC_ 前缀
#      这个也在 Settings → API 页面，叫 service_role key

# Supabase 项目 URL（示例：https://xxxxx.supabase.co）
PUBLIC_SUPABASE_URL=

# Supabase Anon Key — 可安全暴露给浏览器
PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key — 仅构建时使用，跳过 RLS，请勿公开
SUPABASE_SERVICE_ROLE_KEY=


# ──────────────────────────────────────────────────────────────
# 📦 Cloudflare R2 — 图片/文件存储
# ──────────────────────────────────────────────────────────────
# 免费额度：10 GB 存储 · 1000 万次 Class A 操作 · 1000 万次 Class B 操作
#
# 📝 获取步骤：
#   1. 访问 https://dash.cloudflare.com 并注册/登录
#   2. 左侧菜单 → R2 → 点击 "Create bucket"
#      - Bucket Name: blog-images（或任意名）
#      - Location: 选择 Asia Pacific（如果主要受众在亚洲）
#   3. 创建后进入 Bucket → Settings → Public Access
#      - 开启 "R2.dev Subdomain"（允许通过 public URL 访问文件）
#      - 开启后你会得到一个形如 https://pub-xxxxx.r2.dev 的公网域名
#   4. 获取 API Token：
#      左侧菜单 → R2 → Manage R2 API Tokens → Create API Token
#      - Token Name: blog-upload
#      - Permissions: Object Read & Write
#      - 选择你刚创建的 Bucket
#      - 点击创建后会显示 Access Key ID 和 Secret Access Key（只显示一次！）
#   5. 获取 Account ID：
#      登录后 Cloudflare Dashboard 右侧 → 复制 Account ID（32位十六进制字符串）

# Cloudflare Account ID（在 Dashboard 首页右侧）
R2_ACCOUNT_ID=

# R2 API Token — Access Key ID
R2_ACCESS_KEY_ID=

# R2 API Token — Secret Access Key
R2_SECRET_ACCESS_KEY=

# R2 Bucket 名称（如 blog-images）
R2_BUCKET_NAME=

# R2 公网访问域名（开启 r2.dev 后获得，如 https://pub-xxxxx.r2.dev）
PUBLIC_R2_PUBLIC_URL=


# ──────────────────────────────────────────────────────────────
# 💬 Giscus — 基于 GitHub Discussions 的评论系统
# ──────────────────────────────────────────────────────────────
# 免费额度：完全免费，评论数据存在 GitHub Discussions 中
#
# 📝 获取步骤：
#   1. 访问你的博客 GitHub 仓库，进入 Settings
#   2. 勾选 "Discussions" 功能（如果还没开启）
#   3. 访问 https://giscus.app/zh-CN
#   4. 在输入框中填入你的仓库名（如 your-username/your-repo）
#   5. 页面会自动验证并给出配置值
#   6. 选择 "Discussion 的标题包含页面的路径" 作为映射方式
#   7. 选择一个分类（如 Announcements 或新建一个 "Comments" 分类）
#   8. 复制页面下方显示的以下值：
#      - data-repo（即下面的 PUBLIC_GISCUS_REPO）
#      - data-repo-id（即下面的 PUBLIC_GISCUS_REPO_ID）
#      - data-category-id（即下面的 PUBLIC_GISCUS_CATEGORY_ID）

# GitHub 仓库（格式：owner/repo，如 myname/my-blog）
PUBLIC_GISCUS_REPO=

# 仓库 ID（在 Giscus 配置页面生成）
PUBLIC_GISCUS_REPO_ID=

# 分类 ID（在 Giscus 配置页面生成）
PUBLIC_GISCUS_CATEGORY_ID=


# ──────────────────────────────────────────────────────────────
# 📊 Cloudflare Web Analytics — 隐私友好的站点分析
# ──────────────────────────────────────────────────────────────
# 免费额度：完全免费，无采样，不限 PV
#
# 📝 获取步骤（部署后配置，可先跳过）：
#   1. 访问 https://dash.cloudflare.com
#   2. 左侧菜单 → Analytics & Logs → Web Analytics
#   3. 点击 "Add a site"
#   4. 输入你的 Pages 域名（如 xxxx.pages.dev）
#   5. Cloudflare Pages 会自动注入分析脚本，无需手动添加代码
#
# 本变量仅用于文档记录，代码中无需用到它
# PUBLIC_CF_ANALYTICS_TOKEN=
