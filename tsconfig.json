{
	"extends": "astro/tsconfigs/strictest",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true
	},
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}