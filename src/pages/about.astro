---
// ─── 关于页（毛玻璃风格） ───
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于我和这个博客">
  <div class="mx-auto max-w-2xl">
    <!-- 头像 + 名称 -->
    <div class="mb-10 text-center">
      <div class="mx-auto mb-4 flex h-24 w-24 items-center justify-center rounded-full bg-[hsl(var(--primary))] text-4xl font-bold text-[hsl(var(--primary-foreground))] shadow-lg shadow-[hsl(var(--primary))/0.3]">
        R
      </div>
      <h1 class="text-3xl font-bold" style="font-family: 'Noto Serif SC', serif;">
        关于我
      </h1>
      <p class="mt-3 text-[hsl(var(--muted-foreground))]">
        全栈开发者 · 技术爱好者 · 终身学习者
      </p>
    </div>

    <!-- 个人简介 -->
    <div class="glass-card mb-6 p-6">
      <h2 class="mb-3 text-lg font-semibold">📋 简介</h2>
      <p class="leading-relaxed text-[hsl(var(--muted-foreground))]">
        欢迎来到我的个人博客。这里记录了我的学习笔记、技术思考和项目实践。
        博客基于 <strong>Astro SSG</strong> 构建，托管在 GitHub Pages。
      </p>
      <p class="mt-2 leading-relaxed text-[hsl(var(--muted-foreground))]">
        设计灵感来自
        <a
          href="https://github.com/Xinghongia/Kirameku"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-[hsl(var(--primary))] hover:underline"
        >
          Starhiro / Kirameku
        </a>
        的毛玻璃风格 — 感谢开源社区的优秀作品。
      </p>
    </div>

    <!-- 技术栈 -->
    <div class="glass-card mb-6 p-6">
      <h2 class="mb-3 text-lg font-semibold">🛠️ 技术栈</h2>
      <div class="flex flex-wrap gap-2">
        {['TypeScript', 'Astro', 'React', 'TailwindCSS', 'Node.js', 'Python', 'Git', 'Linux', 'Supabase', 'Docker'].map((tech) => (
          <span class="inline-block rounded-full bg-[hsl(var(--primary))/0.12] px-3 py-1 text-xs font-medium text-[hsl(var(--primary))]">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- 联系方式 -->
    <div class="glass-card mb-6 p-6">
      <h2 class="mb-3 text-lg font-semibold">📬 联系方式</h2>
      <div class="space-y-3">
        <a
          href="https://github.com/Silva6c"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-lg p-2 transition-colors hover:bg-[hsl(var(--primary))/0.08]"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="text-sm">GitHub</span>
          <span class="ml-auto text-xs text-[hsl(var(--muted-foreground))]">@Silva6c</span>
        </a>
        <div class="flex items-center gap-3 rounded-lg p-2">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="text-sm">邮箱</span>
          <span class="ml-auto text-xs text-[hsl(var(--muted-foreground))]">待配置</span>
        </div>
      </div>
    </div>

    <!-- 博客信息 -->
    <div class="glass-card p-6 text-center text-sm text-[hsl(var(--muted-foreground))]">
      <p>🪙 本博客运行成本：<strong class="text-[hsl(var(--foreground))]">￥0.00/月</strong></p>
      <p class="mt-1">托管于 GitHub Pages · 无限免费带宽</p>
    </div>
  </div>
</BaseLayout>
