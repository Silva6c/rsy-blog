---
// ─── 文章列表页（毛玻璃风格） ───
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { BASE, SITE_NAME } from '@/lib/constants';
import { formatDate, estimateReadingTime } from '@/lib/utils';

const articles = await getCollection('blog');
const publishedArticles = articles
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const allTags = [...new Set(publishedArticles.flatMap((a) => a.data.tags))].sort();
---

<BaseLayout title="文章" description="所有博客文章">
  <div class="mx-auto max-w-3xl">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-bold" style="font-family: 'Noto Serif SC', serif;">文章</h1>
      <p class="mt-2 text-[hsl(var(--muted-foreground))]">
        共 {publishedArticles.length} 篇文章
      </p>
    </div>

    {
      publishedArticles.length === 0 ? (
        <div class="glass-card p-12 text-center">
          <p class="text-[hsl(var(--muted-foreground))]">还没有文章</p>
        </div>
      ) : (
        <div class="space-y-4">
          {publishedArticles.map((article) => (
            <a
              href={`${BASE}blog/${article.slug}`}
              class="glass-card group block p-6 no-underline"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <h2 class="text-lg font-semibold text-[hsl(var(--foreground))] transition-colors group-hover:text-[hsl(var(--primary))]">
                    {article.data.title}
                  </h2>
                  {article.data.excerpt && (
                    <p class="mt-1 line-clamp-2 text-sm text-[hsl(var(--muted-foreground))]">
                      {article.data.excerpt}
                    </p>
                  )}
                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    {article.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="inline-block rounded-full bg-[hsl(var(--primary))/0.1] px-2 py-0.5 text-xs text-[hsl(var(--primary))]">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <time class="shrink-0 text-xs text-[hsl(var(--muted-foreground))]">
                  {formatDate(article.data.publishedAt)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
