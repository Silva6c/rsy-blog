---
// ─── 首页 — 文章列表（毛玻璃风格） ───
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { BASE, SITE_NAME } from '@/lib/constants';

// 获取所有已发布的文章，按日期降序
const articles = await getCollection('blog');
const publishedArticles = articles
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// 收集所有标签
const allTags = [...new Set(publishedArticles.flatMap((a) => a.data.tags))].sort();
---

<BaseLayout
  title="首页"
  description="一个零运行成本的个人技术博客 — 分享全栈开发、云计算和安全技术"
>
  <!-- Hero 区域 -->
  <section class="mb-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl" style="font-family: 'Noto Serif SC', serif;">
      <span class="text-gradient-brand">
        {SITE_NAME}
      </span>
    </h1>
    <p class="mt-4 text-lg text-[hsl(var(--muted-foreground))]">
      基于 Astro + GitHub Pages 构建 · 记录学习、思考与创造
    </p>
  </section>

  <!-- 文章列表 -->
  <section>
    {
      publishedArticles.length === 0 ? (
        <div class="glass-card text-center py-20">
          <div class="mb-4 text-5xl">📝</div>
          <p class="text-[hsl(var(--muted-foreground))] text-lg">
            还没有文章，敬请期待...
          </p>
          <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]/70">
            新文章请添加到 <code class="rounded bg-[hsl(var(--code-bg))] px-1.5 py-0.5 text-xs">src/content/blog/</code> 目录
          </p>
        </div>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2">
          {publishedArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      )
    }
  </section>

</BaseLayout>
