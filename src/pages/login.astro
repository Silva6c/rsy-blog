---
// ─── 登录页 ───
// 使用 Supabase Auth 进行邮箱登录和 OAuth 登录
// 登录成功后跳转到管理面板

import BaseLayout from '@/layouts/BaseLayout.astro';
import LoginForm from '@/components/LoginForm.tsx';
---

<BaseLayout
  title="登录"
  description="登录到管理面板"
>
  <div class="mx-auto max-w-md">
    <!-- 标题 -->
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold">登录</h1>
      <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
        登录后可管理文章和查看统计数据
      </p>
    </div>

    <!-- 登录表单（React Island — 需要客户端交互） -->
    <LoginForm client:load />

    <!-- 说明 -->
    <p class="mt-6 text-center text-xs text-[hsl(var(--muted-foreground))]">
      未配置 Supabase？请在 <code class="rounded bg-[hsl(var(--code-bg))] px-1 py-0.5">.env</code> 中设置环境变量后重新构建
    </p>
  </div>
</BaseLayout>
