---
// ─── 液态玻璃背景 — SVG feTurbulence 水纹晃动 ───
---

<div class="fixed inset-0 z-[-3] overflow-hidden pointer-events-none">
  <!-- SVG 滤镜定义 -->
  <svg class="absolute inset-0 w-0 h-0">
    <defs>
      <!-- 水纹扰动 -->
      <filter id="water-ripple" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.015 0.02"
          numOctaves="3"
          seed="2"
          result="noise"
        >
          <animate
            attributeName="baseFrequency"
            values="0.015 0.02; 0.018 0.023; 0.012 0.019; 0.015 0.02"
            dur="12s"
            repeatCount="indefinite"
          />
          <animate
            attributeName="seed"
            values="2;5;8;2"
            dur="20s"
            repeatCount="indefinite"
          />
        </feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="35" xChannelSelector="R" yChannelSelector="G" />
      </filter>

      <!-- 玻璃柔光 -->
      <filter id="glass-blur">
        <feGaussianBlur stdDeviation="60" />
      </filter>

      <!-- 光线折射 -->
      <filter id="caustic">
        <feTurbulence type="turbulence" baseFrequency="0.04 0.06" numOctaves="2" seed="3" result="noise">
          <animate attributeName="baseFrequency" values="0.04 0.06; 0.05 0.07; 0.03 0.05; 0.04 0.06" dur="8s" repeatCount="indefinite" />
        </feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="20" xChannelSelector="R" yChannelSelector="B" />
      </filter>
    </defs>
  </svg>

  <!-- 水层：柔光色块在水纹滤镜下晃动 -->
  <div class="absolute inset-0" style="filter: url(#water-ripple);">
    <!-- 蓝色水团 -->
    <div
      class="absolute w-[600px] h-[600px] rounded-full blur-3xl"
      style="
        background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, transparent 70%);
        top: 30%;
        left: 10%;
        animation: water-sway-1 14s ease-in-out infinite;
      "
    />
    <!-- 紫色水团 -->
    <div
      class="absolute w-[500px] h-[500px] rounded-full blur-3xl"
      style="
        background: radial-gradient(circle, rgba(168,85,247,0.2) 0%, transparent 70%);
        top: 10%;
        right: 15%;
        animation: water-sway-2 16s ease-in-out infinite;
      "
    />
    <!-- 青色水团 -->
    <div
      class="absolute w-[450px] h-[450px] rounded-full blur-3xl"
      style="
        background: radial-gradient(circle, rgba(6,182,212,0.18) 0%, transparent 70%);
        bottom: 20%;
        left: 30%;
        animation: water-sway-3 18s ease-in-out infinite;
      "
    />
    <!-- 粉色微光 -->
    <div
      class="absolute w-[350px] h-[350px] rounded-full blur-3xl"
      style="
        background: radial-gradient(circle, rgba(236,72,153,0.12) 0%, transparent 70%);
        bottom: 15%;
        right: 10%;
        animation: water-sway-1 15s ease-in-out infinite reverse;
      "
    />
  </div>

  <!-- 光线焦散层 -->
  <div class="absolute inset-0 opacity-30" style="filter: url(#caustic);">
    <div
      class="absolute w-[300px] h-[800px] -rotate-12"
      style="
        background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.08) 40%, rgba(168,85,247,0.06) 60%, transparent);
        top: -20%;
        left: 30%;
        animation: light-sweep 10s ease-in-out infinite;
      "
    />
  </div>

  <!-- 暗色渐变遮罩 -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#0d0b1a]/30 via-transparent to-[#0d0b1a]/60" />
</div>

<style>
  @keyframes water-sway-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(40px, -30px) scale(1.08); }
    50%      { transform: translate(-20px, 20px) scale(0.94); }
    75%      { transform: translate(30px, 10px) scale(1.04); }
  }

  @keyframes water-sway-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(-35px, 25px) scale(1.06); }
    50%      { transform: translate(25px, -15px) scale(0.92); }
    75%      { transform: translate(-20px, -20px) scale(1.05); }
  }

  @keyframes water-sway-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(20px, -20px) scale(0.95); }
    50%      { transform: translate(-30px, 15px) scale(1.07); }
    75%      { transform: translate(15px, 25px) scale(0.93); }
  }

  @keyframes light-sweep {
    0%, 100% { transform: translate(0, 0) rotate(-12deg); opacity: 0.3; }
    50%      { transform: translate(60px, -20px) rotate(-12deg); opacity: 0.6; }
  }
</style>
