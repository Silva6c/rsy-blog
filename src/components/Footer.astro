---
import { SITE_NAME } from '@/lib/constants';
---
<footer class="border-t border-[hsl(var(--border))] bg-[hsl(var(--background-secondary))]">
  <div class="mx-auto max-w-4xl px-4 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <!-- 版权 -->
      <p class="text-sm text-[hsl(var(--muted-foreground))]">
        &copy; {new Date().getFullYear()} {SITE_NAME}
      </p>

      <!-- 技术栈标签 -->
      <div class="flex flex-wrap items-center justify-center gap-2 text-xs text-[hsl(var(--muted-foreground))]">
        <span class="rounded-full bg-[hsl(var(--muted))] px-2.5 py-1">Astro SSG</span>
        <span class="rounded-full bg-[hsl(var(--muted))] px-2.5 py-1">GitHub Pages</span>
        <span class="rounded-full bg-[hsl(var(--muted))] px-2.5 py-1">Supabase</span>
        <span class="rounded-full bg-[hsl(var(--muted))] px-2.5 py-1">￥0/月</span>
      </div>
    </div>

    <!-- 底部信息 -->
    <p class="mt-3 text-center text-xs text-[hsl(var(--muted-foreground))/0.6]">
      基于 Astro + TailwindCSS + Shadcn UI 构建 · 托管于 GitHub Pages · 无限免费带宽
    </p>
  </div>
</footer>
