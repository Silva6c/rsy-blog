---
import { SITE_NAME } from '@/lib/constants';
---
<footer class="glass-card mt-auto rounded-none border-x-0 border-b-0">
  <div class="mx-auto max-w-5xl px-4 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <!-- 版权 -->
      <p class="text-sm text-[hsl(var(--muted-foreground))]">
        &copy; {new Date().getFullYear()} {SITE_NAME}
      </p>

      <!-- 技术栈标签 -->
      <div class="flex flex-wrap items-center justify-center gap-2 text-xs text-[hsl(var(--muted-foreground))]">
        <span class="glass-button text-xs cursor-default">Astro SSG</span>
        <span class="glass-button text-xs cursor-default">GitHub Pages</span>
        <span class="glass-button text-xs cursor-default">Framer Motion</span>
        <span class="glass-button text-xs cursor-default">￥0/月</span>
      </div>
    </div>

    <!-- 底部信息 -->
    <p class="mt-3 text-center text-xs text-[hsl(var(--muted-foreground))/0.5]">
      基于 Astro + TailwindCSS + Framer Motion 构建 · 托管于 GitHub Pages · 无限免费带宽
    </p>
  </div>
</footer>
